\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 1: MONTHLY REVENUE TREND WITH MOM GROWTH & COHORT ANALYSIS
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Track revenue trajectory, identify seasonality, calculate growth rates
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Revenue planning, forecasting, seasonal strategy
\par \hich\af31506\dbch\af31505\loch\f31506 WITH monthly_metrics AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     DATE_TRUNC('month', order_date)::DATE AS month,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT order_id) AS total_orders,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT customer_id) AS unique_customers,
\par \hich\af31506\dbch\af31505\loch\f31506     SUM(revenue) AS total_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506     ROUND(AVG(revenue), 2) AS avg_order_value,
\par \hich\af31506\dbch\af31505\loch\f31506     SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) AS return_rate_pct
\par \hich\af31506\dbch\af31505\loch\f31506   FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506   WHERE return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY 1
\par \hich\af31506\dbch\af31505\loch\f31506 )
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   month,
\par \hich\af31506\dbch\af31505\loch\f31506   total_orders,
\par \hich\af31506\dbch\af31505\loch\f31506   unique_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   total_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   avg_order_value,
\par \hich\af31506\dbch\af31505\loch\f31506   return_rate_pct * 100 AS return_rate,
\par \hich\af31506\dbch\af31505\loch\f31506   LAG(total_revenue) OVER (ORDER BY month) AS prev_month_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(((total_revenue - LAG(total_revenue) OVER (ORDER BY month)) / 
\par \hich\af31506\dbch\af31505\loch\f31506          LAG(total_revenue) OVER (ORDER BY month) * 100), 2) AS mom_growth_pct,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(total_revenue) OVER (ORDER BY month ROWS BETWEEN 2 PRECEDING AND CURRENT ROW), 0) AS moving_avg_3m
\par \hich\af31506\dbch\af31505\loch\f31506 FROM monthly_metrics
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY month DESC;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 2: CUSTOMER SEGMENTATION BY RFM (RECENCY, FREQUENCY, MONETARY)
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Segment customers for targeted campaigns
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Personalization, retention strategy, revenue maximization
\par \hich\af31506\dbch\af31505\loch\f31506 WITH snapshot AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT MAX(order_date) + 1 AS today FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506 ),
\par \hich\af31506\dbch\af31505\loch\f31506 rfm_metrics AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     o.customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506     (SELECT today FROM snapshot) - MAX(o.order_date) AS recency_days,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT o.order_id) AS frequency,
\par \hich\af31506\dbch\af31505\loch\f31506     SUM(o.revenue) AS monetary,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT DATE_TRUNC('month', o.order_date)) AS months_active
\par \hich\af31506\dbch\af31505\loch\f31506   FROM orders o
\par \hich\af31506\dbch\af31505\loch\f31506   WHERE o.return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY o.customer_id
\par \hich\af31506\dbch\af31505\loch\f31506 ),
\par \hich\af31506\dbch\af31505\loch\f31506 rfm_scores AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506     recency_days,
\par \hich\af31506\dbch\af31505\loch\f31506     frequency,
\par \hich\af31506\dbch\af31505\loch\f31506     monetary,
\par \hich\af31506\dbch\af31505\loch\f31506     NTILE(5) OVER (ORDER BY recency_days DESC) AS r_score,  -- Higher is better (recently active)
\par \hich\af31506\dbch\af31505\loch\f31506     NTILE(5) OVER (ORDER BY frequency DESC) AS f_score,      -- Higher is better (frequent buyer)
\par \hich\af31506\dbch\af31505\loch\f31506     NTILE(5) OVER (ORDER BY monetary DESC) AS m_score         -- Higher is better (high value)
\par \hich\af31506\dbch\af31505\loch\f31506   FROM rfm_metrics
\par \hich\af31506\dbch\af31505\loch\f31506 ),
\par \hich\af31506\dbch\af31505\loch\f31506 customer_segments AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506     recency_days,
\par \hich\af31506\dbch\af31505\loch\f31506     frequency,
\par \hich\af31506\dbch\af31505\loch\f31506     monetary,
\par \hich\af31506\dbch\af31505\loch\f31506     r_score,
\par \hich\af31506\dbch\af31505\loch\f31506     f_score,
\par \hich\af31506\dbch\af31505\loch\f31506     m_score,
\par \hich\af31506\dbch\af31505\loch\f31506     CASE
\par \hich\af31506\dbch\af31505\loch\f31506       WHEN r_score >= 4 AND f_score >= 4 THEN 'Champion'
\par \hich\af31506\dbch\af31505\loch\f31506       WHEN r_score >= 3 AND f_score >= 3 THEN 'Loyal'
\par \hich\af31506\dbch\af31505\loch\f31506       WHEN r_score >= 4 AND f_score <= 2 THEN 'New Customer'
\par \hich\af31506\dbch\af31505\loch\f31506       WHEN r_score BETWEEN 2 AND 3 AND f_score >= 3 THEN 'At Risk'
\par \hich\af31506\dbch\af31505\loch\f31506       WHEN r_score <= 1 AND f_score >= 3 THEN 'Lost'
\par \hich\af31506\dbch\af31505\loch\f31506       ELSE 'Need Attention'
\par \hich\af31506\dbch\af31505\loch\f31506     END AS segment
\par \hich\af31506\dbch\af31505\loch\f31506   FROM rfm_scores
\par \hich\af31506\dbch\af31505\loch\f31506 )
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   segment,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(*) AS customer_count,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(COUNT(*)::FLOAT / SUM(COUNT(*)) OVER () * 100, 2) AS pct_of_base,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(recency_days), 1) AS avg_recency_days,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(frequency), 2) AS avg_purchase_frequency,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(monetary), 2) AS avg_clv,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(monetary) AS total_segment_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(monetary)::FLOAT / SUM(SUM(monetary)) OVER () * 100, 2) AS revenue_contribution_pct
\par \hich\af31506\dbch\af31505\loch\f31506 FROM customer_segments
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY segment
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY total_segment_revenue DESC;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 3: TOP 20 CUSTOMERS BY REVENUE WITH PURCHASE FREQUENCY RANKING
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Identify VIP customers, personalization targets
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Focus retention on high-value customers
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   o.customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT o.order_id) AS total_purchases,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT DATE_TRUNC('month', o.order_date)::DATE) AS months_active,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(o.revenue) AS total_lifetime_value,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(o.revenue), 2) AS avg_order_value,
\par \hich\af31506\dbch\af31505\loch\f31506   MAX(o.order_date) AS last_purchase_date,
\par \hich\af31506\dbch\af31505\loch\f31506   (CURRENT_DATE - MAX(o.order_date)::DATE) AS days_since_last_purchase,
\par \hich\af31506\dbch\af31505\loch\f31506   RANK() OVER (ORDER BY SUM(o.revenue) DESC) AS revenue_rank,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(o.revenue)::FLOAT / SUM(SUM(o.revenue)) OVER () * 100, 3) AS pct_of_total_revenue
\par \hich\af31506\dbch\af31505\loch\f31506 FROM orders o
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE o.return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY o.customer_id
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY total_lifetime_value DESC
\par \hich\af31506\dbch\af31505\loch\f31506 LIMIT 20;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 4: PRODUCT CATEGORY PERFORMANCE & CROSS-CATEGORY AFFINITY
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Identify high-performing categories, bundling opportunities
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Category marketing, inventory optimization, pricing strategy
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   category,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT order_id) AS order_count,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT customer_id) AS unique_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(quantity) AS units_sold,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(revenue) AS total_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(revenue), 2) AS avg_order_value,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(revenue) / COUNT(DISTINCT order_id), 2) AS revenue_per_order,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) * 100, 2) AS return_rate_pct,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(discount) / COUNT(*), 2) AS avg_discount_given,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(delivery_time), 1) AS avg_delivery_days,
\par \hich\af31506\dbch\af31505\loch\f31506   RANK() OVER (ORDER BY SUM(revenue) DESC) AS revenue_rank,
\par \hich\af31506\dbch\af31505\loch\f31506   PERCENT_RANK() OVER (ORDER BY SUM(revenue) DESC) AS revenue_percentile
\par \hich\af31506\dbch\af31505\loch\f31506 FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY category
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY total_revenue DESC;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 5: MONTHLY COHORT RETENTION ANALYSIS (COHORT MONTHS)
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Understand customer lifecycle, retention dropoff, reactivation opportunities
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Retention strategy, cohort-specific interventions, LTV modeling
\par \hich\af31506\dbch\af31505\loch\f31506 WITH cohort_analysis AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     o.customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506     DATE_TRUNC('month', MIN(o.order_date))::DATE AS cohort_month,
\par \hich\af31506\dbch\af31505\loch\f31506     DATE_TRUNC('month', o.order_date)::DATE AS order_month,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT o.order_id) AS orders_in_month
\par \hich\af31506\dbch\af31505\loch\f31506   FROM orders o
\par \hich\af31506\dbch\af31505\loch\f31506   WHERE o.return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY o.customer_id, DATE_TRUNC('month', o.order_date)::DATE
\par \hich\af31506\dbch\af31505\loch\f31506 ),
\par \hich\af31506\dbch\af31505\loch\f31506 cohort_with_offset AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     cohort_month,
\par \hich\af31506\dbch\af31505\loch\f31506     order_month,
\par \hich\af31506\dbch\af31505\loch\f31506     (EXTRACT(YEAR FROM order_month)::INT * 12 + EXTRACT(MONTH FROM order_month)::INT) -
\par \hich\af31506\dbch\af31505\loch\f31506     (EXTRACT(YEAR FROM cohort_month)::INT * 12 + EXTRACT(MONTH FROM cohort_month)::INT) AS month_offset,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT customer_id) AS active_customers
\par \hich\af31506\dbch\af31505\loch\f31506   FROM cohort_analysis
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY cohort_month, order_month
\par \hich\af31506\dbch\af31505\loch\f31506 ),
\par \hich\af31506\dbch\af31505\loch\f31506 cohort_size AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     cohort_month,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT customer_id) AS cohort_customers
\par \hich\af31506\dbch\af31505\loch\f31506   FROM cohort_analysis
\par \hich\af31506\dbch\af31505\loch\f31506   WHERE month_offset = 0
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY cohort_month
\par \hich\af31506\dbch\af31505\loch\f31506 )
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   c.cohort_month,
\par \hich\af31506\dbch\af31505\loch\f31506   cs.cohort_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   c.month_offset,
\par \hich\af31506\dbch\af31505\loch\f31506   c.active_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(c.active_customers::FLOAT / cs.cohort_customers * 100, 1) AS retention_pct
\par \hich\af31506\dbch\af31505\loch\f31506 FROM cohort_with_offset c
\par \hich\af31506\dbch\af31505\loch\f31506 JOIN cohort_size cs ON c.cohort_month = cs.cohort_month
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE month_offset BETWEEN 0 AND 12
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY cohort_month DESC, month_offset;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 6: REPEAT PURCHASE ANALYSIS & CUSTOMER LOYALTY
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Identify repeat buyers vs one-time purchasers, calculate loyalty metrics
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Repeat rate improvement, acquisition vs retention spend
\par \hich\af31506\dbch\af31505\loch\f31506 WITH customer_purchase_count AS (
\par \hich\af31506\dbch\af31505\loch\f31506   SELECT
\par \hich\af31506\dbch\af31505\loch\f31506     customer_id,
\par \hich\af31506\dbch\af31505\loch\f31506     COUNT(DISTINCT order_id) AS purchase_count,
\par \hich\af31506\dbch\af31505\loch\f31506     SUM(revenue) AS lifetime_value,
\par \hich\af31506\dbch\af31505\loch\f31506     MIN(order_date) AS first_purchase_date,
\par \hich\af31506\dbch\af31505\loch\f31506     MAX(order_date) AS last_purchase_date,
\par \hich\af31506\dbch\af31505\loch\f31506     (MAX(order_date)::DATE - MIN(order_date)::DATE) AS customer_lifetime_days
\par \hich\af31506\dbch\af31505\loch\f31506   FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506   WHERE return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506   GROUP BY customer_id
\par \hich\af31506\dbch\af31505\loch\f31506 )
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   CASE
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN purchase_count = 1 THEN '1 Purchase'
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN purchase_count BETWEEN 2 AND 3 THEN '2-3 Purchases'
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN purchase_count BETWEEN 4 AND 6 THEN '4-6 Purchases'
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN purchase_count >= 7 THEN '7+ Purchases'
\par \hich\af31506\dbch\af31505\loch\f31506   END AS purchase_frequency,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(*) AS customer_count,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(COUNT(*)::FLOAT / SUM(COUNT(*)) OVER () * 100, 2) AS pct_of_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(lifetime_value), 2) AS avg_clv,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(lifetime_value) AS segment_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(customer_lifetime_days), 0) AS avg_customer_tenure_days,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(lifetime_value) / SUM(SUM(lifetime_value)) OVER () * 100, 2) AS revenue_contribution_pct
\par \hich\af31506\dbch\af31505\loch\f31506 FROM customer_purchase_count
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY purchase_frequency
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY CAST(SPLIT_PART(purchase_frequency, ' ', 1) AS INT);
