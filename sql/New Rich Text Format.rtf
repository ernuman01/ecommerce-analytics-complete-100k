\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 7: PAYMENT METHOD & GEOGRAPHIC ANALYSIS
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Understand payment preferences, regional performance
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Payment gateway optimization, regional marketing strategy
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   payment_method,
\par \hich\af31506\dbch\af31505\loch\f31506   state,
\par \hich\af31506\dbch\af31505\loch\f31506   city,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT order_id) AS order_count,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT customer_id) AS unique_customers,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(revenue) AS total_revenue,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(revenue), 2) AS avg_order_value,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) * 100, 2) AS return_rate_pct,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(delivery_time), 1) AS avg_delivery_days,
\par \hich\af31506\dbch\af31505\loch\f31506   RANK() OVER (PARTITION BY payment_method ORDER BY SUM(revenue) DESC) AS rank_by_payment
\par \hich\af31506\dbch\af31505\loch\f31506 FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506 WHERE return_flag IN (0, 1)
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY payment_method, state, city
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY payment_method, total_revenue DESC;
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- }{\rtlch\fcs1 \af1 \ltrch\fcs0 \f1\insrsid5968138 \loch\af1\dbch\af31505\hich\f1 \u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d
\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d\u9552\'2d}{\rtlch\fcs1 \af31507 \ltrch\fcs0 \insrsid5968138 
\par 
\par \hich\af31506\dbch\af31505\loch\f31506 -- QUERY 8: RETURN RATE ANALYSIS & PRODUCT QUALITY SCORING
\par \hich\af31506\dbch\af31505\loch\f31506 -- Purpose: Identify problematic products/categories, quality issues
\par \hich\af31506\dbch\af31505\loch\f31506 -- Business Impact: Supply chain optimization, product culling, vendor management
\par \hich\af31506\dbch\af31505\loch\f31506 SELECT
\par \hich\af31506\dbch\af31505\loch\f31506   category,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT product_id) AS product_count,
\par \hich\af31506\dbch\af31505\loch\f31506   COUNT(DISTINCT order_id) AS total_orders,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END) AS return_count,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) * 100, 2) AS return_rate_pct,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(CASE WHEN return_flag = 0 THEN revenue ELSE 0 END) AS net_revenue_kept,
\par \hich\af31506\dbch\af31505\loch\f31506   SUM(CASE WHEN return_flag = 1 THEN revenue ELSE 0 END) AS lost_revenue_to_returns,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(SUM(CASE WHEN return_flag = 1 THEN revenue ELSE 0 END)::FLOAT / SUM(revenue) * 100, 2) AS pct_revenue_lost,
\par \hich\af31506\dbch\af31505\loch\f31506   ROUND(AVG(delivery_time), 1) AS avg_delivery_days,
\par \hich\af31506\dbch\af31505\loch\f31506   CASE
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) < 0.05 THEN 'Excellent'
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) < 0.1 THEN 'Good'
\par \hich\af31506\dbch\af31505\loch\f31506     WHEN SUM(CASE WHEN return_flag = 1 THEN 1 ELSE 0 END)::FLOAT / COUNT(*) < 0.15 THEN 'Fair'
\par \hich\af31506\dbch\af31505\loch\f31506     ELSE 'Poor'
\par \hich\af31506\dbch\af31505\loch\f31506   END AS quality_rating
\par \hich\af31506\dbch\af31505\loch\f31506 FROM orders
\par \hich\af31506\dbch\af31505\loch\f31506 GROUP BY category
\par \hich\af31506\dbch\af31505\loch\f31506 ORDER BY return_rate_pct DESC;
\par 
